# Copy this file to .env and fill in values if you add paid data sources later.
# Currently the project is 100% local — no API keys required.

# Ollama endpoint (default: local)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=qwen3:30b

# API server port
API_PORT=8088

# IBKR TWS/Gateway connection (for live options chain via ib_insync)
# Leave blank to use BSM premium estimates instead.
IB_HOST=127.0.0.1
IB_PORT=7497
IB_CLIENT_ID=1

# Optional: Polygon.io for historical options data (free tier available)
# POLYGON_API_KEY=your_key_here

# Optional: Finviz Elite (required only for some scraper endpoints)
# FINVIZ_EMAIL=you@example.com
# FINVIZ_PASSWORD=your_password_here
